//Escreva um programa que leia um valor inteiro N. Este N é a quantidade de linhas de saída que serão apresentadas na execução do programa.
#include <iostream>

using namespace std;

int main()
{
    int N;
    cin >> N;
    
    int num=1;
    for(int i = 0; i < N; i++){
        cout << num << " " << num+1 << " " << num+2 << " PUM" << endl;
        num += 4;
    }

    return 0;
}
